# Canonical fleet / production APK variables (copy to .env.prod — file is gitignored).
# Sync to EAS before building: npm run env:sync:preview  (internal fleet APK)
#                              npm run env:sync:production (Play Store / production env)
# Verify: npm run verify:env-prod && npm run verify:clerk-convex

# ── Baked into APK at EAS build time (EXPO_PUBLIC_*) ─────────────────────────

# Convex backend — cloud (*.convex.cloud) or self-hosted https URL
EXPO_PUBLIC_CONVEX_URL=https://your-convex-api.example.com

# Clerk — use pk_live_… for production fleet; pk_test_… only for dev (100 emails/month cap)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key

# Google Maps — enable Maps SDK for Android; restrict key to com.surveyapp.app
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=your_google_maps_android_key
EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=your_google_maps_ios_key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_android_key

# Optional — Convex HTTP actions / webhooks (web backend only; not bundled in APK)
# CONVEX_SITE_URL=https://your-convex-site.example.com

# ── CLI only (never synced to EAS / not bundled in APK) ───────────────────────

# Self-hosted Convex deploy (../sdv-front-new-app): npx convex deploy
# CONVEX_SELF_HOSTED_URL=https://your-convex-api.example.com
# CONVEX_SELF_HOSTED_ADMIN_KEY=convex-self-hosted|your_admin_key

# Local Expo tunnel (npm run dev:tunnel) — optional
# NGROK_AUTHTOKEN=
