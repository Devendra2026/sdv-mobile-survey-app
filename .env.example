EXPO_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT-SLUG.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://YOUR-DEPLOYMENT-SLUG.convex.site

# Must match NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY in ../sdv-front-new-app/.env.local
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWT_ISSUER_DOMAIN=https://organic-halibut-21.clerk.accounts.dev

# Optional — Expo tunnel
NGROK_AUTHTOKEN=

